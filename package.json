{
  "name": "testing-anthropic",
  "version": "0.1.0",
  "description": "Minimal TypeScript CLI for testing the Anthropic API.",
  "type": "module",
  "private": true,
  "bin": {
    "testing-anthropic": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "eval": "bun run src/eval/cli.ts",
    "rag": "bun run src/rag/cli.ts",
    "build": "bun build src/index.ts --outdir dist --target bun --minify",
    "start": "bun run dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "latest",
    "@huggingface/transformers": "^4.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^6"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
